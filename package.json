{
  "name": "basa-radiation-guide",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run --passWithNoTests",
    "content:extract": "tsx scripts/content/extract.ts",
    "content:ocr": "tsx scripts/content/ocr.ts",
    "content:ocr:recognize": "tsx scripts/content/recognizeOcr.ts",
    "content:build": "tsx scripts/content/build.ts",
    "content:validate": "tsx scripts/content/validate.ts",
    "rag:index": "tsx scripts/rag/index.ts",
    "worker:dev": "wrangler dev --config worker/wrangler.toml",
    "worker:deploy": "wrangler deploy --config worker/wrangler.toml"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260616.1",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fast-xml-parser": "^5.9.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wrangler": "^4.100.0"
  }
}
